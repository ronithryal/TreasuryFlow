# Perplexity Agent API (server-side only, never bundled)
# Get your API key from https://www.perplexity.ai
PERPLEXITY_API_KEY=your_api_key_here

# Optional: override the agent proxy URL for production deployments
# In dev, defaults to /api/agent-proxy (Vite dev proxy injects the bearer token)
# VITE_AGENT_PROXY_URL=https://your-proxy-domain.com

# ────────────────────────────────────────────────────────────────────────────
# Demo execution mode
#   "mock"    — Zustand-only, deterministic seed data (default)
#   "testnet" — Wagmi/viem + Base Sepolia onchain execution
# Set to "testnet" on the testnet.treasuryflow.com Vercel project.
# ────────────────────────────────────────────────────────────────────────────
VITE_APP_MODE=mock

# WalletConnect / Reown project id
VITE_WC_PROJECT_ID=

# Alchemy key for Base Sepolia RPC
VITE_ALCHEMY_KEY=

# Deployed contract addresses (Base Sepolia). Required when VITE_APP_MODE=testnet.
VITE_MOCK_USDC_ADDRESS=
VITE_TREASURY_VAULT_ADDRESS=

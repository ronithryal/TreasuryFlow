# ────────────────────────────────────────────────────────────────────────────
# TWO VERCEL PROJECTS — same repo (main branch), different env vars:
#   demo-treasuryflow    → set VITE_APP_MODE=mock   (no other vars needed)
#   testnet-treasuryflow → set all VITE_* vars below
# Set env vars manually in the Vercel dashboard per project. Never commit .env.
# ────────────────────────────────────────────────────────────────────────────

# Perplexity Agent API key (server-side only, never bundled into client)
# Get yours at https://www.perplexity.ai
PERPLEXITY_API_KEY=

# Optional: override the agent proxy URL for production deployments
# In dev, defaults to /api/agent-proxy (Vite dev proxy injects the bearer token)
# VITE_AGENT_PROXY_URL=https://your-proxy-domain.com

# ────────────────────────────────────────────────────────────────────────────
# Demo execution mode
#   "mock"    — Zustand-only, deterministic seed data (default)
#   "testnet" — Wagmi/viem + Base Sepolia onchain execution
# ────────────────────────────────────────────────────────────────────────────
VITE_APP_MODE=mock

# WalletConnect / Reown project ID (from cloud.reown.com)
VITE_WC_PROJECT_ID=

# Alchemy API key — key only, not the full RPC URL
VITE_ALCHEMY_KEY=

# Deployed contract addresses on Base Sepolia (required when VITE_APP_MODE=testnet)
VITE_MOCK_USDC_ADDRESS=
VITE_TREASURY_VAULT_ADDRESS=

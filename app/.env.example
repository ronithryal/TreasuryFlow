# ────────────────────────────────────────────────────────────────────────────
# TREASURYFLOW ENVIRONMENT CONFIGURATION
# ────────────────────────────────────────────────────────────────────────────

# ────────────────────────────────────────────────────────────────────────────
# 1. CLIENT / PUBLIC (VITE_ prefix)
# ────────────────────────────────────────────────────────────────────────────

# Demo execution mode: "mock" (default) or "testnet"
VITE_APP_MODE=mock

# WalletConnect / Reown project ID (from https://cloud.reown.com)
VITE_WC_PROJECT_ID=

# Alchemy API key (for RPC provider stability)
VITE_ALCHEMY_KEY=

# Base Sepolia P0 Contract Addresses (P0 refactor_demo deployment)
VITE_MOCK_USDC_ADDRESS=0x240fb77d1c6bbe72bb59a08b379c7d94e905839b
VITE_POLICY_ENGINE_ADDRESS=0x0f01f0632a35493b63c87a4a422a783213abad0e
VITE_LEDGER_CONTRACT_ADDRESS=0x7e97006ccaf3050ae1f5c2187baab1b03287c12b
VITE_TREASURY_VAULT_ADDRESS=0x5f88f257cd264d0cfb2844debc8ea04406be8a1d
VITE_INTENT_REGISTRY_ADDRESS=0x53eb4406785aa86b64c662102745fc85cf93d459

# Optional: Override the agent proxy URL (defaults to local /api/agent-proxy)
# VITE_AGENT_PROXY_URL=

# ────────────────────────────────────────────────────────────────────────────
# 2. SERVER / PRIVATE (No VITE_ prefix, never bundled into client)
# ────────────────────────────────────────────────────────────────────────────

# Perplexity Agent API key (Get yours at https://www.perplexity.ai)
PERPLEXITY_API_KEY=

# Exa API key (semantic search / web research)
EXA_API_KEY=

# AgentMail API key (internal use only — for agent-driven API sign-ups)
# NEVER commit this key or share it. Keep in .env.local only.
AGENTMAIL_API_KEY=

# Hermes agent base URL and API key
HERMES_BASE_URL=
HERMES_API_KEY=

# Fireworks AI API key (used by Hermes / market context service)
FIREWORKS_API_KEY=

# NemoClaw agent (future plug-in, not required for v1)
NEMOCLAW_BASE_URL=
NEMOCLAW_API_KEY=

# Base Sepolia RPC URL (Full URL including key)
BASE_SEPOLIA_RPC_URL=

# Demo Approver Private Key (The "Treasury Admin" signer)
# SECURITY WARNING: Use a fresh, Base Sepolia-ONLY wallet. Never fund on mainnet.
DEMO_APPROVER_KEY=

# ────────────────────────────────────────────────────────────────────────────
# 3. CDP (Coinbase Developer Platform) — server-side only
# ────────────────────────────────────────────────────────────────────────────

# CDP API credentials (from https://cdp.so)
CDP_API_KEY=
CDP_SECRET_KEY=
CDP_BASE_URL=https://api.cdp.so/v1

# CDP dashboard / web URLs for the TreasuryVault contract
CDP_WEB_URL=
CDP_DASHBOARD_URL=

# ────────────────────────────────────────────────────────────────────────────
# 4. FEATURE FLAGS
# ────────────────────────────────────────────────────────────────────────────

# OpenFX cross-border FX rail (scaffold only — keep false for v1)
OPENFX_ENABLED=false

# ────────────────────────────────────────────────────────────────────────────
# ⚠️ SECURITY REMINDERS
# ────────────────────────────────────────────────────────────────────────────
# 1. NEVER use the VITE_ prefix for private keys or secrets.
# 2. NEVER commit .env or .env.local files to version control.
# 3. Role separation: Production approvals will use Safe, WalletConnect, or CDP.
# 4. Use .env.local for your local development overrides.
